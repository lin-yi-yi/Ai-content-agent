APP_ENV=local
APP_NAME=AI Content Growth Agent
BACKEND_CORS_ORIGINS=http://localhost:5173

# MySQL
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/ai_content_agent?charset=utf8mb4

# LLM default
DEFAULT_LLM_PROVIDER=local
DEFAULT_LLM_MODEL=local-rule-based-v0

# Optional per-task model routing
TOPIC_SCORE_PROVIDER=local
TOPIC_SCORE_MODEL=local-rule-based-v0
DRAFT_GENERATION_PROVIDER=local
DRAFT_GENERATION_MODEL=local-rule-based-v0
CARD_GENERATION_PROVIDER=local
CARD_GENERATION_MODEL=local-rule-based-v0
COMPLIANCE_CHECK_PROVIDER=local
COMPLIANCE_CHECK_MODEL=local-rule-based-v0

# OpenAI-compatible providers
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-1-5-pro-32k

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
